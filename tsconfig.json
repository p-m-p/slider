{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "~/packages/react": ["./packages/react/src"],
      "~/packages/components": ["./packages/components/src"],
      "~/packages/slider": ["./packages/slider/src"]
    }
  },
  "exclude": ["node_modules", "packages"],
  "references": [
    { "path": "./packages/slider" },
    { "path": "./packages/components" },
    { "path": "./packages/react" }
  ]
}
